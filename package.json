{
  "name": "gabios",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "cf-typegen": "wrangler types",
    "deploy": "npm run build && wrangler deploy",
    "dev": "react-router dev",
    "postinstall": "npm run cf-typegen",
    "preview": "npm run build && vite preview",
    "typecheck": "npm run cf-typegen && react-router typegen && tsc -b",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply gabios-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply gabios-db --remote",
    "db:studio": "drizzle-kit studio",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.53",
    "ai": "^6.0.168",
    "better-auth": "^1.0.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.0.0",
    "isbot": "^5.1.31",
    "lucide-react": "^0.460.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router": "^7.10.0",
    "workers-ai-provider": "^3.1.11",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.0.0",
    "@cloudflare/vite-plugin": "^1.13.5",
    "@playwright/test": "^1.59.1",
    "@react-router/dev": "^7.10.0",
    "@tailwindcss/vite": "^4.1.13",
    "@types/node": "^22.19.17",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "drizzle-kit": "^0.31.4",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.2",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^5.1.4",
    "wrangler": "^4.83.0"
  }
}
